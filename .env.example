# ─────────────────────────────────────────────
# Boundless Flux AI — Environment Variables
# Copy this file to .env.local and fill in values
# Never commit .env.local to version control
# ─────────────────────────────────────────────

# n8n Webhook (contact form submission)
# Create a Webhook trigger in n8n and paste the URL here
N8N_WEBHOOK_URL=https://your-n8n-instance.cloud/webhook/contact-form

# Supabase (database for leads and submissions)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Resend (email notifications)
RESEND_API_KEY=re_your_resend_api_key

# Calendly (strategy call booking link)
NEXT_PUBLIC_CALENDLY_URL=https://calendly.com/your-username/strategy-call

# Google Analytics (optional)
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Site URL (used for OG metadata and canonical links)
NEXT_PUBLIC_SITE_URL=https://boundlessflux.ai
